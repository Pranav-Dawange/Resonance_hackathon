# ============================================
# Clinderma SkinVision — Environment Variables
# Copy this file to .env and replace with your credentials
# ============================================

# Firebase Configuration (Optional — app works without it using demo data)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000:web:000

# API Configuration (defaults to localhost:8000)
# VITE_API_BASE_URL=http://localhost:8000
